REFLEXION_RUNTIME=llm

# Option 1: OpenAI-compatible API
OPENAI_API_KEY=your_api_key_here
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Option 2: Anthropic / AgentRouter API
ANTHROPIC_API_KEY=your_api_key_here
ANTHROPIC_MODEL=claude-opus-4-6
ANTHROPIC_BASE_URL=https://agentrouter.org

# Optional speed controls
# Use these if your provider supports faster models.
# ACTOR_MODEL=claude-3-5-haiku-20241022
# EVALUATOR_MODEL=claude-3-5-haiku-20241022
# REFLECTOR_MODEL=claude-3-5-haiku-20241022
# REFLEXION_EVALUATOR=exact
# REFLEXION_CONTEXT_CHUNKS=4
# REFLEXION_REQUEST_DELAY_SECONDS=3.2
# REFLEXION_RATE_LIMIT_BACKOFF_SECONDS=65
